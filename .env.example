# =====================================================
# בדרך טובים — קובץ דוגמה למשתני סביבה
# העתק ל-.env.local ומלא לפי השירותים שלך.
# =====================================================

# --- אתר ---
NEXT_PUBLIC_SITE_URL=https://example.com
NEXT_PUBLIC_SITE_NAME="בדרך טובים"
NEXT_PUBLIC_AUTHOR_NAME="שם הכותב"

# --- מסד נתונים: Neon ---
# https://console.neon.tech
# לאפליקציה (Vercel): Pooled connection (-pooler ב-host).
# ל-db:push / db:migrate מקומי: אם יש שגיאת WebSocket — השתמש ב-Direct (ללא pooler).
DATABASE_URL=postgres://user:password@ep-xxx.region.neon.tech/dbname?sslmode=require

# --- Auth.js ---
# צור עם: openssl rand -base64 32  (או: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
AUTH_SECRET=replace-me-with-random-32-bytes
AUTH_URL=https://example.com
AUTH_TRUST_HOST=true

# --- Google OAuth ---
# https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Cloudflare R2 (אחסון קבצים) ---
# https://dash.cloudflare.com -> R2 -> Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=goodness-way
R2_PUBLIC_BASE_URL=

# --- מייל: Resend ---
# https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL="בדרך טובים <notifications@example.com>"
AUTHOR_NOTIFY_EMAIL=author@example.com

# --- LLM ---
# pluggable: openai | anthropic | google
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# --- CloudConvert (אופציונלי, להמרת .doc ישן) ---
# אם ריק - הכותב יקבל הודעה לשמור כ-docx
CLOUDCONVERT_API_KEY=

# --- Rate Limiting (Upstash Redis) ---
# אופציונלי; אם ריק - in-memory rate limit פר instance
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
